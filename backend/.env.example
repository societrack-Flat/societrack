APP_ENV=dev

APP_NAME=societrack-backend



# Supabase (required for any DB from the API: payments, webhooks, etc.)
# In Azure App Service, add the same as Application settings; use the *service role* key from
# Supabase → Project Settings → API (never the anon key).

SUPABASE_URL=

SUPABASE_SERVICE_ROLE_KEY=



# For verifying Supabase JWTs locally (optional)

# If not provided, the API will accept tokens but only do minimal structure checks.

SUPABASE_JWT_SECRET=



# CORS (comma-separated)

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Razorpay (Orders API + payment verification). Secret must never be exposed to the browser.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxx
# Webhook-only: Razorpay Dashboard → Account & Settings → Webhooks → (your URL) → secret
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxx

# Optional: POST /api/maintenance/rollover-cron with header X-Maintenance-Rollover-Secret
# MAINTENANCE_ROLLOVER_SECRET=

