# Copy to .env and fill in values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used for password-reset and magic-link redirects (must match Supabase → Authentication → URL Configuration).
# Dev: http://localhost:5173
# Prod: https://your-domain.com
VITE_APP_URL=http://localhost:5173

VITE_API_BASE_URL=http://localhost:8000

# Shown in Support chat (headphones icon) on admin + superadmin dashboards
VITE_SUPPORT_PHONE=+91-00000-00000
VITE_SUPPORT_EMAIL=support@societrack.com
