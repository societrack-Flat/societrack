# Copy to .env and fill in values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used for password-reset and magic-link redirects (must match Supabase → Authentication → URL Configuration).
# Dev: http://localhost:5173
# Prod: https://your-domain.com
VITE_APP_URL=http://localhost:5173

VITE_API_BASE_URL=http://localhost:8000

# Razorpay Checkout key id (public). Same as RAZORPAY_KEY_ID in Razorpay dashboard — required for payment UI.
# Optional if your flow only injects key from the server; our create-order API returns key_id.
# VITE_RAZORPAY_KEY_ID=

# Shown in Support chat (headphones icon) on admin + superadmin dashboards
VITE_SUPPORT_PHONE=+91 8142112121
VITE_SUPPORT_EMAIL=support@societrack.com
